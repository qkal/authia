{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:integration": "vitest run \"tests/integration/cycle1-reference-flow.test.ts\"",
    "test:oauth": "vitest run \"tests/integration/cycle2-oauth-reference-flow.test.ts\"",
    "test:oauth:required": "node --eval \"if (!process.env.TEST_DATABASE_URL) { console.error('TEST_DATABASE_URL must be set for test:oauth:required'); process.exit(1); }\" && vitest run \"tests/integration/cycle2-oauth-reference-flow.test.ts\"",
    "example:cycle1": "node --eval \"import('./examples/cycle1-compose.ts').then(() => console.log('cycle1 composition module loaded'))\""
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
